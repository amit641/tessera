{
  "name": "select",
  "displayName": "Select",
  "version": "0.1.0",
  "import": "import { Select } from \"@tessera/react\";",
  "description": "Single-select listbox (combobox pattern): typeahead, disabled-item skipping, keyboard navigation, anchored positioning.",
  "anatomy": [
    {
      "part": "root",
      "element": "div",
      "stable": true
    },
    {
      "part": "label",
      "element": "span",
      "stable": true
    },
    {
      "part": "trigger",
      "element": "button[role=combobox]",
      "stable": true
    },
    {
      "part": "value",
      "element": "span",
      "stable": true
    },
    {
      "part": "indicator",
      "element": "span",
      "stable": true
    },
    {
      "part": "positioner",
      "element": "div",
      "stable": true
    },
    {
      "part": "content",
      "element": "ul[role=listbox]",
      "stable": true
    },
    {
      "part": "item",
      "element": "li[role=option]",
      "stable": true
    },
    {
      "part": "itemText",
      "element": "span",
      "stable": true
    },
    {
      "part": "itemIndicator",
      "element": "span",
      "stable": true
    }
  ],
  "props": [
    {
      "name": "items",
      "type": "{ value: string; label: string; disabled?: boolean }[]",
      "required": true
    },
    {
      "name": "label",
      "type": "string"
    },
    {
      "name": "placeholder",
      "type": "string",
      "default": "\"Select an option\""
    },
    {
      "name": "value / defaultValue",
      "type": "string | null"
    },
    {
      "name": "onValueChange",
      "type": "(value: string | null) => void"
    },
    {
      "name": "disabled",
      "type": "boolean"
    }
  ],
  "a11y": {
    "roles": [
      "combobox trigger",
      "listbox",
      "option"
    ],
    "keyboard": [
      {
        "key": "ArrowDown/ArrowUp",
        "action": "opens / moves highlight"
      },
      {
        "key": "Enter / Space",
        "action": "selects highlighted option"
      },
      {
        "key": "Home/End",
        "action": "first/last option"
      },
      {
        "key": "printable chars",
        "action": "typeahead"
      },
      {
        "key": "Escape",
        "action": "closes"
      }
    ],
    "notes": [
      "Focus stays on the trigger; aria-activedescendant tracks the highlighted option."
    ]
  },
  "styling": {
    "selectors": [
      "[data-scope=\"select\"][data-part=\"item\"]"
    ],
    "stateAttributes": [
      "data-state=open|closed (trigger)",
      "data-highlighted",
      "data-placeholder"
    ]
  },
  "examples": [
    "<Select label=\"Framework\" items={[{ value: \"react\", label: \"React\" }, { value: \"vue\", label: \"Vue\" }]} onValueChange={setFramework} />"
  ],
  "category": "forms"
}
