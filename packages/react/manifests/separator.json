    {
      "name": "orientation",
      "type": "\"horizontal\" | \"vertical\"",
      "default": "\"horizontal\""
    },
    {
      "name": "decorative",
      "type": "boolean",
      "default": "false",
      "description": "Hides from assistive tech when purely visual."
    }
  ],
  "a11y": {
    "roles": [
      "separator"
    ],
    "keyboard": [],
    "notes": []
  },
  "styling": {
    "selectors": [
      "[data-scope=\"separator\"][data-part=\"root\"]"
    ],
    "stateAttributes": [
      "data-orientation"
    ]
  },
  "examples": [
    "<Separator />"
  ]
}
